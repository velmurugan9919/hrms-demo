# Database (Railway provides DATABASE_URL automatically when you add PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/hrms?schema=public"

# NextAuth
AUTH_SECRET="your-secret-key-here"
AUTH_URL="http://localhost:4001"
AUTH_TRUST_HOST="true"

# For Railway Production:
# DATABASE_URL - Automatically set by Railway PostgreSQL addon
# AUTH_URL - Set to your Railway app URL (e.g., https://your-app.railway.app)
# AUTH_SECRET - Generate with: openssl rand -base64 32
